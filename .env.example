# Seshn environment variables. Copy to .env.local for local dev, and set the
# same in Vercel (Project → Settings → Environment Variables) for deploys.
# The app builds and runs without these; payments stay dormant until they're set.

# ── Supabase (public; safe in the browser, RLS-protected) ──────────────
# These have hardcoded fallbacks in lib/seshn/config.ts, so they're optional.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase service role (SERVER ONLY — never expose) ─────────────────
# Required for Stripe webhooks / Connect routes to write locked-down columns
# (profiles.stripe_account_id, escrows, …). Supabase dashboard → Project
# Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                     # sk_test_… (server only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # pk_test_… (browser)
STRIPE_WEBHOOK_SECRET=                 # whsec_… (from the webhook endpoint)

# Platform economics (optional; defaults shown).
PLATFORM_FEE_BPS=500                   # Seshn's cut, basis points (500 = 5%)
STRIPE_PCT_BPS=290                     # card % fee estimate for gross-up (2.9%)
STRIPE_FIXED_CENTS=30                  # card fixed fee estimate (30¢)

# ── Spotify (optional; profile "connect" flow) ─────────────────────────
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Seshn environment variables. Copy to .env.local for local dev, and set the
# same in Vercel (Project → Settings → Environment Variables) for deploys.
# The app builds and runs without these; payments stay dormant until they're set.

# ── Supabase (public; safe in the browser, RLS-protected) ──────────────
# These have hardcoded fallbacks in lib/seshn/config.ts, so they're optional.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase service role (SERVER ONLY — never expose) ─────────────────
# Required for Stripe webhooks / Connect routes to write locked-down columns
# (profiles.stripe_account_id, escrows, …). Supabase dashboard → Project
# Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                     # sk_test_… (server only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # pk_test_… (browser)
STRIPE_WEBHOOK_SECRET=                 # whsec_… (from the webhook endpoint)

# Cron auth (server). Set this to any long random string; Vercel automatically
# sends it as "Authorization: Bearer <CRON_SECRET>" on scheduled invocations.
# Required for the escrow auto-release / refund sweep (vercel.json crons) to run.
CRON_SECRET=

# Platform economics (optional; defaults shown).
PLATFORM_FEE_BPS=1000                  # Seshn's cut, basis points (1000 = 10%)
STRIPE_PCT_BPS=290                     # card % fee estimate, absorbed by Seshn (2.9%)
STRIPE_FIXED_CENTS=30                  # card fixed fee estimate, absorbed by Seshn (30¢)

# ── Transactional email (optional; dormant until set) ──────────────────
# Powers email notifications (escrow updates, help replies, applications, …) via
# the /api/notifications/email bridge, which a Supabase Database Webhook calls on
# every notifications INSERT. Without RESEND_API_KEY the bridge is a no-op.
RESEND_API_KEY=                        # Resend API key (re_…)
EMAIL_FROM=Seshn <hello@seshnnn.com>   # verified sender on a domain you control
NOTIFICATIONS_WEBHOOK_SECRET=          # shared secret; send as header x-webhook-secret from the Supabase webhook
NEXT_PUBLIC_SITE_URL=https://www.seshnnn.com  # base URL for links in emails

# ── Error tracking (optional; dormant until set) ──────────────────────
# Sentry. Without a DSN the SDK is a complete no-op (no network, no events).
# Set both to the same DSN (server + browser). Add SENTRY_AUTH_TOKEN later if you
# want source-map upload via withSentryConfig.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Spotify (optional; profile "connect" flow) ─────────────────────────
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
